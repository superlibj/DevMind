# Application Configuration
APP_NAME="AI Code Development Agent"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
WEBSOCKET_PATH=/ws
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Security Configuration
JWT_SECRET_KEY=aiagent-super-secure-jwt-key-2024-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Security Scanning
ENABLE_CODE_SCANNING=true
BANDIT_CONFIG_PATH=
SEMGREP_RULES_PATH=

# LLM Configuration
DEFAULT_LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Local Models (optional)
LOCAL_MODEL_ENDPOINT=http://localhost:11434
LOCAL_MODEL_NAME=codellama

# LLM Settings
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=30

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost/aiagent
ECHO_SQL=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
CACHE_TTL=300

# Tool Configuration
GIT_ENABLED=true
VIM_ENABLED=true
FILE_OPERATIONS_ENABLED=true

# Tool Limits
TOOL_TIMEOUT_SECONDS=30
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_EXTENSIONS=.py,.js,.ts,.java,.cpp,.c,.go,.rs,.php,.rb

# Agent Configuration
AGENT_MAX_ITERATIONS=10
AGENT_MEMORY_LIMIT_MB=100
CONVERSATION_HISTORY_LIMIT=50

# ReAct Configuration
REACT_MAX_STEPS=5
REACT_TIMEOUT_SECONDS=60